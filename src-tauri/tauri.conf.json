{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Awesome Music Player",
  "version": "0.1.0",
  "identifier": "com.awesomemusicplayer.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Awesome Music Player",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' asset: http://asset.localhost https://asset.localhost tauri: blob: data:; img-src 'self' asset: http://asset.localhost https://asset.localhost tauri: blob: data:; media-src 'self' asset: http://asset.localhost https://asset.localhost tauri: blob: data:; connect-src 'self' asset: http://asset.localhost https://asset.localhost tauri: blob: data: https://itunes.apple.com;",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
